# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.ygmjglskunvqhqysyper
DB_PASSWORD=your_supabase_database_password
DATABASE_URL=postgresql://postgres.ygmjglskunvqhqysyper:your_supabase_database_password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DB_SSL=true

# ─── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=careers18_access_secret_32chars_minimum
JWT_REFRESH_SECRET=careers18_refresh_secret_32chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── LinkedIn OAuth ────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/v1/auth/linkedin/callback

# ─── Google SMTP (Gmail) ───────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@careers18.com
FROM_NAME=Careers18

# ─── OTP ───────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Paytm ─────────────────────────────────────────────────────
PAYTM_MID=your_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CHANNEL_ID=WEB
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_BASE_URL=https://securegw-stage.paytm.in

# ─── CCAvenue ──────────────────────────────────────────────────
CCAVENUE_MERCHANT_ID=your_merchant_id
CCAVENUE_ACCESS_CODE=your_access_code
CCAVENUE_WORKING_KEY=your_working_key
CCAVENUE_BASE_URL=https://test.ccavenue.com

# ─── FreeCash / Generic Wallet ─────────────────────────────────
FREECASH_API_KEY=your_freecash_api_key
FREECASH_SECRET=your_freecash_secret

# ─── Payment Callback (SAME for all gateways) ──────────────────
PAYU_KEY=your_payu_key
PAYU_SALT=your_payu_salt
PAYU_BASE_URL=https://test.payu.in/_payment
PAYU_DEFAULT_EMAIL=noreply@careers18.com
PAYMENT_CALLBACK_URL=http://localhost:3000/api/v1/payments/callback
PAYMENT_SUCCESS_REDIRECT=http://localhost:4200/payment/success
PAYMENT_FAILURE_REDIRECT=http://localhost:4200/payment/failure
